{
    "buildCommand": "vite build",
    "devCommand": "vite --port $PORT",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/app",
            "destination": "/app/index.html"
        },
        {
            "source": "/app/:path*",
            "destination": "/app/index.html"
        }
    ]
}