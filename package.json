    "@types/node": "^22.19.13",
    "@vitejs/plugin-react": "^5.0.0",
    "husky": "^9.1.7",
    "typescript": "~5.8.2",
    "vercel": "^50.25.4",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
